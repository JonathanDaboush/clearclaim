# ClearClaim — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clearclaim
DB_USER=clearclaim
DB_PASSWORD=change-me

# ── Backend server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@clearclaim.example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=ClearClaim <noreply@clearclaim.example.com>

# ── Identity verification provider ───────────────────────────────────────────
# Third-party KYC/identity provider (e.g. Stripe Identity, Jumio, Persona)
IDENTITY_PROVIDER_API_KEY=
IDENTITY_PROVIDER_BASE_URL=https://api.identity-provider.example.com

# ── Evidence file storage ─────────────────────────────────────────────────────
# Local path (relative to backend/) for storing uploaded evidence files
EVIDENCE_STORAGE_PATH=./uploads

# AWS S3 (leave blank to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set in frontend/.env.local — not committed
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_TITLE=ClearClaim
